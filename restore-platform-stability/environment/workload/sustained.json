{
  "name": "sustained",
  "description": "High sustained traffic volume to test resource limits and connection pooling",
  "duration_seconds": 60,
  "target_base_url": "http://localhost:8000",
  "concurrency": 15,
  "phases": [
    {"start_s": 0, "end_s": 60, "requests_per_second": 15}
  ],
  "endpoints": [
    {"method": "POST", "path": "/checkout", "weight": 10, "payload_template": "checkout_small"}
  ],
  "seed": 999
}
