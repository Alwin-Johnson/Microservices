# ==============================================================================
# restore-platform-stability — Environment Variable Reference
#
# Copy this file to .env and fill in appropriate values.
# Never commit .env to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ecommerce
POSTGRES_USER=ecommerce_user
POSTGRES_PASSWORD=changeme

# Constructed DSN — override this or let each service build it from the above.
# DATABASE_URL=postgresql+asyncpg://ecommerce_user:changeme@postgres:5432/ecommerce

# ------------------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# Constructed URL — override this or let each service build it from the above.
# REDIS_URL=redis://redis:6379/0

# ------------------------------------------------------------------------------
# Gateway Service
# ------------------------------------------------------------------------------
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_LOG_LEVEL=info

# Downstream service base URLs (use Docker service names, never localhost)
ORDERS_SERVICE_URL=http://orders:8001
PAYMENTS_SERVICE_URL=http://payments:8002
INVENTORY_SERVICE_URL=http://inventory:8003

# ------------------------------------------------------------------------------
# Orders Service
# ------------------------------------------------------------------------------
ORDERS_HOST=0.0.0.0
ORDERS_PORT=8001
ORDERS_LOG_LEVEL=info

# ------------------------------------------------------------------------------
# Payments Service
# ------------------------------------------------------------------------------
PAYMENTS_HOST=0.0.0.0
PAYMENTS_PORT=8002
PAYMENTS_LOG_LEVEL=info

# ------------------------------------------------------------------------------
# Inventory Service
# ------------------------------------------------------------------------------
INVENTORY_HOST=0.0.0.0
INVENTORY_PORT=8003
INVENTORY_LOG_LEVEL=info

# ------------------------------------------------------------------------------
# Environment
# ------------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=false
