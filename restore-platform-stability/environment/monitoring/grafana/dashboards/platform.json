{
  "title": "Platform Overview",
  "uid": "platform-overview",
  "schemaVersion": 39,
  "refresh": "5s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Request rate by service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum by (service) (rate(http_requests_total[1m]))", "legendFormat": "{{service}}" }
      ]
    },
    {
      "id": 2,
      "title": "Error rate (5xx) by service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (service) (rate(http_requests_total{status=~\"5..\"}[1m])) / sum by (service) (rate(http_requests_total[1m]))",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "p99 request latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le, service) (rate(http_request_duration_seconds_bucket[1m])))",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Retries by service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "sum by (service) (rate(http_retries_total[1m]))", "legendFormat": "{{service}}" }
      ]
    },
    {
      "id": 5,
      "title": "Simulated resource-pool slots in use / leaked",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "sim_pool_slots_in_use", "legendFormat": "{{service}} in_use" },
        { "expr": "sim_pool_slots_leaked", "legendFormat": "{{service}} leaked" }
      ]
    },
    {
      "id": 6,
      "title": "CPU saturation signal (decoy)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "expr": "cpu_saturation_ratio", "legendFormat": "{{service}}" }
      ]
    }
  ]
}
